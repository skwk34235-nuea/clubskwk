<%- include('partials/header') %>

<main class="flex-1 w-full relative overflow-hidden">
    <!-- Background Orbs -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-skwkPink/20 rounded-full blur-[120px] animate-float pointer-events-none"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-neon-blue/10 rounded-full blur-[150px] animate-float-delayed pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-neon-purple/5 rounded-full blur-[200px] pointer-events-none"></div>

    <!-- Hero Section -->
    <section class="relative max-w-5xl mx-auto px-6 pt-20 pb-16 text-center animate-slide-up">
        <!-- Decorative line -->
        <div class="flex items-center justify-center gap-3 mb-8">
            <div class="h-px w-12 bg-gradient-to-r from-transparent to-skwkPink/60"></div>
            <span class="text-xs font-semibold uppercase tracking-[0.3em] text-skwkPink/80">ยินดีต้อนรับ</span>
            <div class="h-px w-12 bg-gradient-to-l from-transparent to-skwkPink/60"></div>
        </div>

        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black mb-6 leading-tight">
            <span class="text-white">ระบบสมัคร</span><br>
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-skwkPink via-neon-pink to-neon-blue text-glow-pink">ชุมนุมออนไลน์</span>
        </h1>

        <p class="text-lg md:text-xl text-gray-400 mb-10 max-w-2xl mx-auto font-light leading-relaxed">
            <%= sysSettings.system_announcement || 'ยินดีต้อนรับสู่ระบบจัดการกิจกรรมชุมนุม โรงเรียนศรีกระนวนวิทยาคม' %>
        </p>

        <% if (!user) { %>
            <a href="/auth/register" class="group relative inline-flex items-center gap-2 px-8 py-4 rounded-2xl text-white font-bold text-lg overflow-hidden transition-all duration-500 hover:scale-105 hover:shadow-neon-pink">
                <span class="absolute inset-0 bg-gradient-to-r from-skwkPink to-neon-pink rounded-2xl"></span>
                <span class="absolute inset-0 bg-gradient-to-r from-neon-pink to-neon-blue opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-2xl"></span>
                <span class="relative flex items-center gap-2">
                    เริ่มต้นใช้งานทันที
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                    </svg>
                </span>
            </a>
        <% } else { %>
            <div class="inline-flex items-center gap-4 px-8 py-4 rounded-2xl bg-white/[0.04] backdrop-blur-xl border border-white/[0.08] shadow-glass">
                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-skwkPink to-neon-blue flex items-center justify-center text-white font-bold text-lg shadow-neon-pink">
                    <%= user.firstname.charAt(0) %>
                </div>
                <div class="text-left">
                    <p class="text-xs text-gray-500 uppercase tracking-widest">ยินดีต้อนรับ</p>
                    <p class="font-bold text-white text-lg"><%= user.firstname %> <%= user.lastname %></p>
                </div>
            </div>
        <% } %>
    </section>

    <!-- Search Bar -->
    <div class="max-w-xl mx-auto px-6 mb-12 animate-slide-up-delayed">
        <div class="relative group">
            <div class="absolute inset-0 bg-neon-blue/15 rounded-2xl blur-xl group-focus-within:bg-neon-blue/25 transition-all"></div>
            <div class="relative bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] rounded-2xl flex items-center px-6 py-4 shadow-glass transition-all group-focus-within:border-neon-blue/40">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 text-gray-500 mr-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="clubSearch" placeholder="ค้นหาชื่อชุมนุม..." 
                       class="bg-transparent border-none text-white text-lg placeholder-gray-600 focus:ring-0 w-full outline-none">
            </div>
        </div>
    </div>

    <!-- Club Section -->
    <section class="max-w-6xl mx-auto px-6 pb-20 animate-slide-up-delayed">
        <!-- Section Header -->
        <div class="flex items-center gap-4 mb-10">
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
            <h2 class="text-2xl md:text-3xl font-bold text-white flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-neon-blue shadow-neon-blue animate-pulse"></span>
                ชุมนุมที่เปิดรับสมัคร
            </h2>
            <div class="h-px flex-1 bg-gradient-to-r from-transparent via-white/10 to-transparent"></div>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% if (clubs && clubs.length > 0) { %>
                <% clubs.forEach((club, index) => { %>
                    <div class="group relative rounded-2xl bg-white/[0.03] backdrop-blur-xl border border-white/[0.06] p-6 transition-all duration-500 hover:-translate-y-2 hover:bg-white/[0.06] hover:border-skwkPink/30 hover:shadow-glass-hover flex flex-col"
                         style="animation: slideUp 0.5s ease-out <%= index * 0.1 %>s both;">
                        
                        <!-- Card glow on hover -->
                        <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-skwkPink/5 to-neon-blue/5 opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
                        
                        <div class="relative z-10 flex flex-col flex-1">
                            <!-- Club icon -->
                            <div class="w-10 h-10 rounded-xl bg-gradient-to-br from-skwkPink/20 to-neon-blue/20 border border-white/[0.06] flex items-center justify-center mb-4 group-hover:shadow-neon-pink transition-shadow duration-500">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-skwkPink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
                                </svg>
                            </div>

                            <h3 class="text-lg font-bold text-white mb-2 group-hover:text-transparent group-hover:bg-clip-text group-hover:bg-gradient-to-r group-hover:from-skwkPink group-hover:to-neon-blue transition-all duration-300">
                                <%= club.name %>
                            </h3>
                            <p class="text-gray-400 text-sm mb-5 flex-1 line-clamp-2 leading-relaxed">
                                <%= club.description || 'ไม่มีรายละเอียด' %>
                            </p>
                            
                            <!-- Progress -->
                            <div class="mb-4">
                                <div class="flex justify-between items-center mb-2 text-xs">
                                    <span class="text-gray-500 uppercase tracking-wider font-medium">ผู้สมัคร</span>
                                    <span id="club-count-<%= club.id %>" class="font-bold text-transparent bg-clip-text bg-gradient-to-r from-skwkPink to-neon-blue">
                                        <%= club.current_students %> / <%= club.max_students %>
                                    </span>
                                </div>
                                <div class="w-full h-1.5 bg-white/[0.06] rounded-full overflow-hidden">
                                    <div class="h-full rounded-full bg-gradient-to-r from-skwkPink to-neon-blue transition-all duration-700 ease-out shadow-neon-pink" 
                                         id="club-progress-<%= club.id %>" 
                                         style="width: <%= (club.current_students / club.max_students) * 100 %>%;"></div>
                                </div>
                            </div>
                            
                            <!-- Action -->
                            <a href="/student/club/<%= club.id %>" class="group/btn flex items-center justify-center gap-2 w-full py-2.5 rounded-xl text-sm font-semibold text-gray-300 border border-white/[0.08] hover:border-skwkPink/50 hover:text-white hover:bg-skwkPink/10 hover:shadow-neon-pink transition-all duration-300">
                                ดูรายละเอียด
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 group-hover/btn:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
                                </svg>
                            </a>
                        </div>
                    </div>
                <% }) %>
            <% } else { %>
                <div class="col-span-full">
                    <div class="text-center py-16 rounded-2xl bg-white/[0.02] border border-white/[0.05] border-dashed backdrop-blur-md">
                        <div class="w-16 h-16 mx-auto mb-4 rounded-2xl bg-white/[0.04] border border-white/[0.06] flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8 text-gray-600" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"/>
                            </svg>
                        </div>
                        <p class="text-gray-500 text-lg font-light">ยังไม่มีการเปิดรับสมัครชุมนุมในขณะนี้</p>
                        <p class="text-gray-600 text-sm mt-2">กรุณาติดตามข่าวสารจากทางโรงเรียน</p>
                    </div>
                </div>
            <% } %>
        </div>
    </section>
</main>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const searchInput = document.getElementById('clubSearch');
        const grid = document.querySelector('.grid');
        const originalCards = Array.from(grid.children);

        if (searchInput) {
            searchInput.addEventListener('input', (e) => {
                const term = e.target.value.toLowerCase().trim();
                
                originalCards.forEach(card => {
                    const title = card.querySelector('h3') ? card.querySelector('h3').textContent.toLowerCase() : '';
                    const desc = card.querySelector('p') ? card.querySelector('p').textContent.toLowerCase() : '';
                    
                    if (title.includes(term) || desc.includes(term)) {
                        card.style.display = 'flex';
                    } else {
                        card.style.display = 'none';
                    }
                });
            });
        }
    });
</script>

<%- include('partials/footer') %>
