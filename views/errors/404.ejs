<%- include('../partials/header') %>

<main class="flex-1 flex flex-col items-center justify-center relative overflow-hidden py-20 px-6">
    <!-- Background Decor -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-skwkPink/10 rounded-full blur-[150px] animate-glow-pulse pointer-events-none"></div>
    
    <div class="z-10 text-center animate-slide-up">
        <div class="relative inline-block mb-10">
            <h1 class="text-[180px] font-black text-white/5 leading-none select-none">404</h1>
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-32 h-32 bg-skwkPink/20 rounded-3xl rotate-12 blur-2xl animate-pulse"></div>
                <div class="relative text-6xl font-black text-white text-glow-pink">Oops!</div>
            </div>
        </div>
        
        <h2 class="text-3xl font-bold text-white mb-4">ไม่พบหน้าที่คุณต้องการ</h2>
        <p class="text-gray-400 mb-12 max-w-md mx-auto font-light leading-relaxed">
            หน้าที่คุณกำลังมองหาอาจถูกลบไปแล้ว เปลี่ยนชื่อ หรือไม่มีอยู่จริงในระบบของเรา
        </p>
        
        <a href="/" class="group relative inline-flex items-center gap-3 px-10 py-4 rounded-2xl text-white font-bold overflow-hidden transition-all duration-500 hover:scale-105 hover:shadow-neon-pink">
            <span class="absolute inset-0 bg-skwkPink rounded-2xl"></span>
            <span class="absolute inset-0 bg-gradient-to-r from-skwkPink to-neon-blue opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-2xl"></span>
            <span class="relative flex items-center gap-2">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
                </svg>
                กลับสู่หน้าหลัก
            </span>
        </a>
