<%- include('../partials/header') %>

<main class="flex-1 flex flex-col items-center justify-center relative overflow-hidden py-20 px-6">
    <!-- Background Decor -->
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-red-500/10 rounded-full blur-[150px] animate-pulse pointer-events-none"></div>
    
    <div class="z-10 text-center animate-slide-up">
        <div class="relative inline-block mb-10">
            <h1 class="text-[180px] font-black text-white/5 leading-none select-none">500</h1>
            <div class="absolute inset-0 flex items-center justify-center">
                <div class="w-32 h-32 bg-red-500/20 rounded-3xl -rotate-12 blur-2xl animate-pulse"></div>
                <div class="relative text-5xl font-black text-white uppercase tracking-tighter">System Error</div>
            </div>
        </div>
        
        <h2 class="text-3xl font-bold text-white mb-4">ขออภัย เกิดข้อผิดพลาดในระบบ</h2>
        <p class="text-gray-400 mb-12 max-w-md mx-auto font-light leading-relaxed">
            ระบบขัดข้องชั่วคราว ทีมผู้พัฒนาทราบข้อมูลแล้วและกำลังดำเนินการแก้ไข กรุณาลองใหม่อีกครั้งในภายหลัง
        </p>
        
        <div class="flex flex-col md:flex-row gap-4 justify-center">
            <button onclick="window.location.reload()" class="px-10 py-4 rounded-2xl bg-white/5 border border-white/10 text-white font-bold hover:bg-white/10 transition-all flex items-center gap-2 justify-center">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 4v5h.582m15.356 2A8.001 8.001 0 004.582 9m0 0H9m11 11v-5h-.581m0 0a8.003 8.003 0 01-15.357-2m15.357 2H15" />
                </svg>
                ลองใหม่อีกครั้ง
            </button>
            <a href="/" class="px-10 py-4 rounded-2xl bg-skwkPink text-white font-bold shadow-neon-pink hover:scale-105 transition-all text-center">
                กลับสู่หน้าหลัก
            </a>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
