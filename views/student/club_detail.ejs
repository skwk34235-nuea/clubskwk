<%- include('../partials/header') %>

<main class="flex-1 w-full relative overflow-hidden py-10 px-6">
    <div class="absolute top-20 right-10 w-80 h-80 bg-neon-blue/10 rounded-full blur-[120px] animate-float pointer-events-none"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-skwkPink/10 rounded-full blur-[150px] animate-float-delayed pointer-events-none"></div>

    <div class="max-w-4xl mx-auto z-10 relative animate-slide-up">
        <a href="/student/apply" class="inline-flex items-center gap-2 text-gray-500 hover:text-white transition-colors mb-8 group">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:-translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
            </svg>
            กลับไปหน้าสมัครชุมนุม
        </a>

        <div class="bg-white/[0.03] backdrop-blur-2xl border border-white/[0.08] rounded-3xl shadow-glass overflow-hidden">
            <div class="relative h-64 md:h-80 overflow-hidden">
                <div class="absolute inset-0 bg-gradient-to-br from-skwkPink/20 via-neon-blue/10 to-transparent"></div>
                <div class="absolute inset-0 flex items-center justify-center">
                    <div class="text-center px-6">
                        <span class="px-3 py-1 rounded-full text-[10px] font-black tracking-[0.2em] uppercase bg-white/10 border border-white/20 text-white mb-4 inline-block backdrop-blur-md">
                            Club Details
                        </span>
                        <h1 class="text-4xl md:text-6xl font-black text-white text-glow-blue tracking-tight"><%= club.name %></h1>
                    </div>
                </div>
                <div class="absolute bottom-0 left-0 w-full h-24 bg-gradient-to-t from-[#050510] to-transparent"></div>
            </div>

            <div class="p-8 md:p-12">
                <div class="grid grid-cols-1 md:grid-cols-3 gap-12">
                    <div class="space-y-8">
                        <div>
                            <p class="text-[10px] uppercase text-gray-500 font-bold tracking-widest mb-3">ครูที่ปรึกษา</p>
                            <div class="flex items-center gap-3 p-4 bg-white/5 rounded-2xl border border-white/5">
                                <div class="w-10 h-10 rounded-full bg-gradient-to-br from-skwkPink to-neon-pink flex items-center justify-center text-white font-bold text-sm shadow-neon-pink">
                                    <%= club.teacher_firstname.charAt(0) %>
                                </div>
                                <div>
                                    <p class="text-sm font-bold text-gray-200"><%= club.teacher_firstname %> <%= club.teacher_lastname %></p>
                                    <p class="text-[10px] text-gray-500">Teacher Advisor</p>
                                </div>
                            </div>
                        </div>

                        <div>
                            <p class="text-[10px] uppercase text-gray-500 font-bold tracking-widest mb-3">ความจุที่รับสมัคร</p>
                            <div class="bg-white/5 border border-white/5 p-6 rounded-3xl text-center">
                                <div class="text-3xl font-black text-white mb-1"><%= club.current_students %> / <%= club.max_students %></div>
                                <div class="w-full h-1.5 bg-white/10 rounded-full overflow-hidden mt-3">
                                    <div class="h-full bg-gradient-to-r from-skwkPink to-neon-blue transition-all duration-1000" style="width: <%= Math.min((club.current_students / club.max_students) * 100, 100) %>%"></div>
                                </div>
                                <p class="text-[10px] text-gray-500 mt-3 font-bold uppercase tracking-widest">สมาชิกปัจจุบัน</p>
                            </div>
                        </div>
                    </div>

                    <div class="md:col-span-2 space-y-8">
                        <div>
                            <h3 class="text-xl font-bold text-white mb-4 flex items-center gap-2">
                                <span class="w-1 h-6 bg-skwkPink rounded-full shadow-neon-pink"></span>
                                เกี่ยวกับชุมนุมนี้
                            </h3>
                            <div class="text-gray-400 leading-relaxed font-light text-lg">
                                <%= club.description || 'ไม่มีรายละเอียดเพิ่มเติม' %>
                            </div>
                        </div>

                        <div class="pt-8 border-t border-white/5">
                            <% if (membership) { %>
                                <div class="bg-white/5 border border-white/10 p-6 rounded-2xl text-center">
                                    <p class="text-gray-400 mb-4">สถานะการสมัครของคุณ:
                                        <span class="font-bold text-skwkPink uppercase tracking-widest"><%= membership.status %></span>
                                    </p>
                                    <a href="/student" class="inline-block px-8 py-3 rounded-xl bg-white/10 text-white font-bold hover:bg-white/20 transition-all">
                                        ไปที่หน้าแดชบอร์ดของคุณ
                                    </a>
                                </div>
                            <% } else if (!registrationOpen) { %>
                                <div class="bg-amber-500/10 border border-amber-500/30 p-6 rounded-2xl text-center text-amber-300 font-bold">
                                    ระบบปิดรับสมัครชั่วคราว กรุณารอประกาศเปิดรับสมัครจากผู้ดูแลระบบ
                                </div>
                            <% } else if (club.status !== 'open') { %>
                                <div class="bg-gray-500/10 border border-white/10 p-6 rounded-2xl text-center text-gray-300 font-bold">
                                    ชุมนุมนี้ยังไม่เปิดรับสมัครในขณะนี้
                                </div>
                            <% } else if (club.current_students >= club.max_students) { %>
                                <div class="bg-red-500/10 border border-red-500/30 p-6 rounded-2xl text-center text-red-400 font-bold">
                                    ขออภัย ชุมนุมนี้เต็มแล้ว
                                </div>
                            <% } else if (hasAnyMembership) { %>
                                <div class="bg-amber-500/10 border border-amber-500/30 p-6 rounded-2xl text-center text-amber-400 font-bold">
                                    คุณได้สมัครชุมนุมอื่นไปแล้ว (สมัครได้เพียง 1 ชุมนุมเท่านั้น)
                                </div>
                            <% } else { %>
                                <form action="/student/club/<%= club.id %>/join" method="POST">
                                    <button type="submit" class="group relative w-full py-5 rounded-2xl text-white font-black text-xl tracking-[0.1em] overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-neon-pink uppercase">
                                        <span class="absolute inset-0 bg-skwkPink rounded-2xl animate-glow-pulse"></span>
                                        <span class="absolute inset-0 bg-gradient-to-r from-skwkPink to-neon-blue opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-2xl"></span>
                                        <span class="relative flex items-center justify-center gap-3">
                                            สมัครเข้าร่วมชุมนุมนี้
                                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                                                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                                            </svg>
                                        </span>
                                    </button>
                                </form>
                                <p class="text-center text-gray-500 text-xs mt-4">หมายเหตุ: คุณสามารถสมัครชุมนุมได้เพียง 1 ชุมนุมต่อปีการศึกษาเท่านั้น</p>
                            <% } %>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
