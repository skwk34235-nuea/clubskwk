<%- include('../partials/header') %>

<main class="flex-1 w-full relative overflow-hidden py-10 px-6">
    <!-- Background Decor -->
    <div class="absolute top-20 left-10 w-72 h-72 bg-skwkPink/10 rounded-full blur-[120px] animate-float pointer-events-none"></div>
    <div class="absolute bottom-20 right-10 w-96 h-96 bg-neon-blue/10 rounded-full blur-[150px] animate-float-delayed pointer-events-none"></div>

    <div class="max-w-6xl mx-auto z-10 relative">
        <header class="mb-10 animate-fade-in text-center md:text-left">
            <h1 class="text-4xl font-black text-white text-glow-pink">แผงควบคุมผู้ดูแลระบบ</h1>
            <p class="text-gray-400 mt-2">ภาพรวมการทำงานของระบบและสถิติต่างๆ</p>
        </header>

        <!-- Stats Grid -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-12 animate-slide-up">
            <!-- Total Users -->
            <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] p-6 rounded-2xl shadow-glass group hover:border-skwkPink/50 transition-all duration-300">
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-skwkPink/20 rounded-xl text-skwkPink shadow-neon-pink group-hover:scale-110 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                        </svg>
                    </div>
                </div>
                <h3 class="text-gray-500 text-sm font-semibold uppercase tracking-wider">ผู้ใช้งานทั้งหมด</h3>
                <p class="text-4xl font-bold text-white mt-1"><%= stats.users %></p>
            </div>

            <!-- Total Clubs -->
            <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] p-6 rounded-2xl shadow-glass group hover:border-neon-blue/50 transition-all duration-300">
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-neon-blue/20 rounded-xl text-neon-blue shadow-neon-blue group-hover:scale-110 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                        </svg>
                    </div>
                </div>
                <h3 class="text-gray-500 text-sm font-semibold uppercase tracking-wider">ชุมนุมทั้งหมด</h3>
                <p class="text-4xl font-bold text-white mt-1"><%= stats.clubs %></p>
            </div>

            <!-- Total Memberships -->
            <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] p-6 rounded-2xl shadow-glass group hover:border-neon-purple/50 transition-all duration-300">
                <div class="flex justify-between items-start mb-4">
                    <div class="p-3 bg-purple-500/20 rounded-xl text-purple-400 shadow-[0_0_15px_rgba(168,85,247,0.4)] group-hover:scale-110 transition-transform">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                </div>
                <h3 class="text-gray-500 text-sm font-semibold uppercase tracking-wider">สมาชิกที่อนุมัติแล้ว</h3>
                <p class="text-4xl font-bold text-white mt-1"><%= stats.members %></p>
            </div>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
            <!-- Quick Actions -->
            <div class="lg:col-span-1 space-y-6 animate-slide-up-delayed">
                <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] p-6 rounded-2xl shadow-glass">
                    <h3 class="text-xl font-bold text-white mb-6">จัดการระบบ</h3>
                    <div class="space-y-3">
                        <a href="/admin/users" class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.05] border border-white/[0.08] hover:bg-white/[0.1] hover:border-skwkPink/50 transition-all duration-300 group">
                            <div class="p-2 bg-skwkPink/20 rounded-lg text-skwkPink">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197M13 7a4 4 0 11-8 0 4 4 0 018 0z" />
                                </svg>
                            </div>
                            <span class="text-gray-200 font-medium">จัดการผู้ใช้งาน</span>
                        </a>
                        <a href="/admin/clubs" class="flex items-center gap-3 p-4 rounded-xl bg-white/[0.05] border border-white/[0.08] hover:bg-white/[0.1] hover:border-neon-blue/50 transition-all duration-300 group">
                            <div class="p-2 bg-neon-blue/20 rounded-lg text-neon-blue">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4" />
                                </svg>
                            </div>
                            <span class="text-gray-200 font-medium">ดูรายชื่อชุมนุม</span>
                        </a>
                    </div>
                </div>
            </div>

            <!-- Recent Users -->
            <div class="lg:col-span-2 animate-slide-up-delayed">
                <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] rounded-2xl shadow-glass overflow-hidden">
                    <div class="p-6 border-b border-white/[0.08] flex justify-between items-center bg-white/[0.01]">
                        <h3 class="text-xl font-bold text-white">ผู้ใช้งานที่ลงทะเบียนล่าสุด</h3>
                        <a href="/admin/users" class="text-sm text-skwkPink hover:text-white transition-colors">ดูทั้งหมด</a>
                    </div>
                    <div class="overflow-x-auto">
                        <table class="w-full text-left">
                            <thead>
                                <tr class="bg-white/[0.02] text-gray-500 text-xs uppercase tracking-widest">
                                    <th class="px-6 py-4 font-semibold">ชื่อ-นามสกุล</th>
                                    <th class="px-6 py-4 font-semibold">ชื่อผู้ใช้</th>
                                    <th class="px-6 py-4 font-semibold">ตำแหน่ง</th>
                                    <th class="px-6 py-4 font-semibold">วันที่สมัคร</th>
                                </tr>
                            </thead>
                            <tbody class="divide-y divide-white/[0.06]">
                                <% recentUsers.forEach(user => { %>
                                    <tr class="hover:bg-white/[0.03] transition-colors">
                                        <td class="px-6 py-4 text-white font-medium">
                                            <%= user.firstname %> <%= user.lastname %>
                                        </td>
                                        <td class="px-6 py-4 text-gray-400">
                                            <%= user.username %>
                                        </td>
                                        <td class="px-6 py-4">
                                            <span class="px-2 py-1 rounded-md text-[10px] uppercase font-bold tracking-wider 
                                                <%= user.role === 'admin' ? 'bg-skwkPink/20 text-skwkPink border border-skwkPink/30' : 
                                                   (user.role === 'teacher' ? 'bg-neon-blue/20 text-neon-blue border border-neon-blue/30' : 
                                                   'bg-gray-500/20 text-gray-400 border border-white/10') %>">
                                                <%= user.role %>
                                            </span>
                                        </td>
                                        <td class="px-6 py-4 text-gray-500 text-sm">
                                            <%= new Date(user.created_at).toLocaleDateString('th-TH') %>
                                        </td>
                                    </tr>
                                <% }) %>
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
