<%- include('../partials/header') %>

<main class="flex-1 w-full relative overflow-hidden py-10 px-6 flex justify-center items-center">
    <div class="absolute top-20 right-10 w-72 h-72 bg-neon-blue/10 rounded-full blur-[120px] animate-float pointer-events-none"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-skwkPink/10 rounded-full blur-[150px] animate-float-delayed pointer-events-none"></div>

    <div class="max-w-3xl w-full z-10 relative animate-slide-up">
        <header class="mb-10 text-center">
            <h1 class="text-4xl font-black text-white text-glow-blue"><%= mode === 'create' ? 'เพิ่มชุมนุมใหม่' : 'แก้ไขข้อมูลชุมนุม' %></h1>
            <p class="text-gray-400 mt-2"><%= mode === 'create' ? 'สร้างชุมนุมและเลือกครูที่ปรึกษาให้พร้อมใช้งาน' : 'อัปเดตรายละเอียดชุมนุม สถานะ และจำนวนรับ' %></p>
        </header>

        <% if (error) { %>
            <div class="bg-red-500/10 border border-red-500/30 text-red-300 p-4 mb-8 rounded-xl backdrop-blur-md font-semibold">
                <%= error %>
            </div>
        <% } %>

        <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] p-8 md:p-10 rounded-3xl shadow-glass">
            <form action="<%= mode === 'create' ? '/admin/clubs/create' : '/admin/clubs/' + club.id + '/edit' %>" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label class="block text-xs font-black text-gray-500 uppercase tracking-widest">ชื่อชุมนุม</label>
                    <input type="text" name="name" value="<%= club.name %>" required class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all">
                </div>

                <div class="space-y-2">
                    <label class="block text-xs font-black text-gray-500 uppercase tracking-widest">รายละเอียด</label>
                    <textarea name="description" rows="4" class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all"><%= club.description || '' %></textarea>
                </div>

                <div class="grid grid-cols-1 md:grid-cols-3 gap-5">
                    <div class="space-y-2">
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest">ครูที่ปรึกษา</label>
                        <select name="teacher_id" required class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all">
                            <option value="">เลือกครู</option>
                            <% teachers.forEach(teacher => { %>
                                <option value="<%= teacher.id %>" <%= String(club.teacher_id) === String(teacher.id) ? 'selected' : '' %>>
                                    <%= teacher.firstname %> <%= teacher.lastname %>
                                </option>
                            <% }) %>
                        </select>
                    </div>
                    <div class="space-y-2">
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest">จำนวนรับ</label>
                        <input type="number" min="1" name="max_students" value="<%= club.max_students %>" required class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all">
                    </div>
                    <div class="space-y-2">
                        <label class="block text-xs font-black text-gray-500 uppercase tracking-widest">สถานะ</label>
                        <select name="status" required class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all">
                            <option value="open" <%= club.status === 'open' ? 'selected' : '' %>>Open</option>
                            <option value="closed" <%= club.status === 'closed' ? 'selected' : '' %>>Closed</option>
                        </select>
                    </div>
                </div>

                <div class="pt-4 flex gap-4">
                    <a href="/admin/clubs" class="flex-1 py-4 rounded-xl text-center text-gray-400 font-bold bg-white/5 border border-white/10 hover:bg-white/10 transition-all">ยกเลิก</a>
                    <button type="submit" class="flex-[2] py-4 rounded-xl bg-skwkPink text-white font-black text-lg shadow-neon-pink hover:scale-[1.02] transition-all">
                        <%= mode === 'create' ? 'สร้างชุมนุม' : 'บันทึกการแก้ไข' %>
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
