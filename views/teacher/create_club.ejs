<%- include('../partials/header') %>

<main class="flex-1 w-full relative overflow-hidden py-10 px-6 flex items-center justify-center" style="min-height: calc(100vh - 130px);">
    <!-- Background Decor -->
    <div class="absolute top-10 right-10 w-64 h-64 bg-neon-blue/15 rounded-full blur-[100px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute bottom-10 left-10 w-80 h-80 bg-skwkPink/15 rounded-full blur-[120px] animate-float pointer-events-none"></div>

    <div class="w-full max-w-2xl z-10 animate-slide-up">
        <div class="rounded-2xl bg-white/[0.03] backdrop-blur-2xl border border-white/[0.07] shadow-glass p-8 md:p-10 relative overflow-hidden">
            <!-- Top glow accent -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-neon-blue/60 to-transparent"></div>
            
            <header class="mb-10 text-center">
                <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-neon-blue/20 to-skwkPink/20 border border-white/[0.08] flex items-center justify-center shadow-neon-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-neon-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                </div>
                <h2 class="text-3xl font-extrabold text-white tracking-wide">สร้างชุมนุมใหม่</h2>
                <p class="text-gray-500 mt-2 text-sm font-light">กรอกข้อมูลรายละเอียดของชุมนุมที่คุณต้องการเปิดรับสมัคร</p>
            </header>

            <% if (locals.error) { %>
                <div class="bg-red-500/10 border border-red-500/30 text-red-300 p-4 mb-6 rounded-xl backdrop-blur-md flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <span class="font-medium text-sm"><%= error %></span>
                </div>
            <% } %>

            <form action="/teacher/club/create" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label for="name" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">ชื่อชุมนุม</label>
                    <input type="text" id="name" name="name" required 
                           class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300 font-medium"
                           placeholder="เช่น ชุมนุมหมากรุกคอมพิวเตอร์">
                </div>
                
                <div class="space-y-2">
                    <label for="max_students" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">จำนวนนักเรียนที่รับสมัคร</label>
                    <input type="number" id="max_students" name="max_students" required min="1" max="100" value="30"
                           class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300 font-medium"
                           placeholder="เช่น 30">
                </div>

                <div class="space-y-2">
                    <label for="description" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">รายละเอียดชุมนุม</label>
                    <textarea id="description" name="description" rows="4" 
                              class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300 font-medium"
                              placeholder="อธิบายสั้นๆ เกี่ยวกับกิจกรรมในชุมนุมของคุณ..."></textarea>
                </div>
                
                <div class="flex gap-4 pt-4">
                    <a href="/teacher" class="flex-1 py-4 rounded-xl text-gray-400 font-bold text-center bg-white/5 border border-white/10 hover:bg-white/10 hover:text-white transition-all duration-300">
                        ยกเลิก
                    </a>
                    <button type="submit" class="flex-[2] group relative py-4 rounded-xl text-white font-bold text-lg tracking-wide overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-neon-blue">
                        <span class="absolute inset-0 bg-gradient-to-r from-neon-blue to-skwkPink rounded-xl"></span>
                        <span class="absolute inset-0 bg-gradient-to-r from-skwkPink to-neon-blue opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-xl"></span>
                        <span class="relative flex items-center justify-center gap-2">
                            บันทึกและสร้างชุมนุม
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                            </svg>
                        </span>
                    </button>
                </div>
            </form>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
