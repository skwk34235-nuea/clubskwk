<%- include('../partials/header') %>

<main class="flex-1 w-full relative overflow-hidden py-10 px-6 flex items-center justify-center">
    <!-- Background Decor -->
    <div class="absolute top-10 left-10 w-64 h-64 bg-neon-blue/15 rounded-full blur-[100px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-skwkPink/15 rounded-full blur-[120px] animate-float pointer-events-none"></div>

    <div class="w-full max-w-2xl z-10 animate-slide-up">
        <div class="rounded-2xl bg-white/[0.03] backdrop-blur-2xl border border-white/[0.07] shadow-glass p-8 md:p-10 relative overflow-hidden">
            <header class="mb-10 text-center">
                <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-skwkPink/20 to-neon-blue/20 border border-white/[0.08] flex items-center justify-center shadow-neon-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                    </svg>
                </div>
                <h2 class="text-3xl font-extrabold text-white tracking-wide">แก้ไขข้อมูลชุมนุม</h2>
                <p class="text-gray-500 mt-2 text-sm font-light">ปรับปรุงข้อมูลรายละเอียดของชุมนุมให้เป็นปัจจุบัน</p>
            </header>

            <% if (locals.error) { %>
                <div class="bg-red-500/10 border border-red-500/30 text-red-300 p-4 mb-6 rounded-xl backdrop-blur-md flex items-center gap-3">
                    <span class="font-medium text-sm"><%= error %></span>
                </div>
            <% } %>

            <form action="/teacher/club/<%= club.id %>/edit" method="POST" class="space-y-6">
                <div class="space-y-2">
                    <label for="name" class="block text-xs font-semibold text-gray-400 uppercase tracking-widest">ชื่อชุมนุม</label>
                    <input type="text" id="name" name="name" value="<%= club.name %>" required 
                           class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all">
                </div>
                
                <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                    <div class="space-y-2">
                        <label for="max_students" class="block text-xs font-semibold text-gray-400 uppercase tracking-widest">จำนวนรับสมัคร</label>
                        <input type="number" id="max_students" name="max_students" value="<%= club.max_students %>" required min="1"
                               class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all">
                    </div>
                    <div class="space-y-2">
                        <label for="status" class="block text-xs font-semibold text-gray-400 uppercase tracking-widest">สถานะชุมนุม</label>
                        <select name="status" id="status" class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all appearance-none cursor-pointer">
                            <option value="open" <%= club.status === 'open' ? 'selected' : '' %>>เปิดรับสมัคร (Open)</option>
                            <option value="closed" <%= club.status === 'closed' ? 'selected' : '' %>>ปิดรับสมัคร (Closed)</option>
                        </select>
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="description" class="block text-xs font-semibold text-gray-400 uppercase tracking-widest">รายละเอียด</label>
                    <textarea id="description" name="description" rows="4" 
                              class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white focus:border-neon-blue/50 focus:bg-white/10 outline-none transition-all"><%= club.description %></textarea>
                </div>
                
                <div class="flex gap-4 pt-4">
                    <a href="/teacher" class="flex-1 py-4 rounded-xl text-gray-400 font-bold text-center bg-white/5 border border-white/10 hover:bg-white/10 transition-all">
                        ยกเลิก
                    </a>
                    <button type="submit" class="flex-[2] py-4 rounded-xl bg-skwkPink text-white font-black text-lg shadow-neon-pink hover:scale-[1.02] transition-all">
                        บันทึกการแก้ไข
                    </button>
                </div>
            </form>

            <div class="mt-10 pt-8 border-t border-white/5">
                <p class="text-xs text-center text-gray-600 mb-4 uppercase tracking-widest font-bold">พื้นที่อันตราย</p>
                <form action="/teacher/club/<%= club.id %>/delete" method="POST" onsubmit="return confirm('คุณแน่ใจหรือไม่ว่าต้องการลบชุมนุมนี้? ข้อมูลสมาชิกทั้งหมดจะถูกลบออกด้วย')">
                    <button type="submit" class="w-full py-3 rounded-xl border border-red-500/20 text-red-500/50 hover:bg-red-500 hover:text-white hover:border-red-500 transition-all text-xs font-bold uppercase tracking-widest">
                        ลบชุมนุมนี้ถาวร
                    </button>
                </form>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
