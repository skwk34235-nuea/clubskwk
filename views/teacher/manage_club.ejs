<%- include('../partials/header') %>

<main class="flex-1 w-full relative overflow-hidden py-10 px-6">
    <!-- Background Decor -->
    <div class="absolute top-20 right-10 w-72 h-72 bg-skwkPink/10 rounded-full blur-[120px] animate-float pointer-events-none"></div>
    <div class="absolute bottom-20 left-10 w-96 h-96 bg-neon-blue/10 rounded-full blur-[150px] animate-float-delayed pointer-events-none"></div>

    <div class="max-w-6xl mx-auto z-10 relative">
        <header class="mb-10 animate-fade-in flex flex-col md:flex-row justify-between items-end gap-6">
            <div class="text-center md:text-left flex-1">
                <div class="flex items-center gap-3 mb-2 justify-center md:justify-start">
                    <span class="px-2 py-0.5 rounded text-[10px] uppercase font-black tracking-widest bg-skwkPink/20 text-skwkPink border border-skwkPink/30">Management</span>
                    <h1 class="text-4xl font-black text-white text-glow-pink tracking-tight"><%= club.name %></h1>
                </div>
                <p class="text-gray-400 max-w-2xl"><%= club.description %></p>
            </div>
            <div class="flex items-center gap-3">
                <a href="/teacher/club/<%= club.id %>/print" target="_blank" class="p-3.5 rounded-2xl bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:bg-white/10 transition-all flex items-center gap-2" title="พิมพ์รายชื่อ">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4a2 2 0 00-2-2H9a2 2 0 00-2 2v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z" />
                    </svg>
                    <span class="hidden md:inline text-xs font-bold uppercase tracking-widest">พิมพ์</span>
                </a>
                <a href="/teacher" class="p-3.5 rounded-2xl bg-white/5 border border-white/10 text-gray-400 hover:text-white hover:bg-white/10 transition-all">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18" />
                    </svg>
                </a>
            </div>
        </header>

        <% if (error === 'club_full') { %>
            <div class="mb-6 rounded-2xl border border-red-500/30 bg-red-500/10 px-5 py-4 text-red-300 font-semibold">
                ไม่สามารถอนุมัติสมาชิกเพิ่มได้ เพราะชุมนุมนี้เต็มแล้ว
            </div>
        <% } else if (error === 'member_not_found') { %>
            <div class="mb-6 rounded-2xl border border-red-500/30 bg-red-500/10 px-5 py-4 text-red-300 font-semibold">
                ไม่พบข้อมูลสมาชิกที่ต้องการอัปเดต
            </div>
        <% } else if (success === 'member_updated') { %>
            <div class="mb-6 rounded-2xl border border-emerald-500/30 bg-emerald-500/10 px-5 py-4 text-emerald-300 font-semibold">
                อัปเดตสถานะสมาชิกเรียบร้อยแล้ว
            </div>
        <% } %>

        <div class="bg-white/[0.03] backdrop-blur-xl border border-white/[0.08] rounded-2xl shadow-glass overflow-hidden animate-slide-up">
            <div class="p-6 border-b border-white/5 bg-white/[0.01]">
                <h3 class="text-xl font-bold text-white flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-skwkPink" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                    </svg>
                    รายชื่อผู้สมัครและสมาชิก
                </h3>
            </div>
            
            <div class="overflow-x-auto">
                <table class="w-full text-left">
                    <thead>
                        <tr class="bg-white/[0.02] text-gray-500 text-[10px] uppercase tracking-widest font-black">
                            <th class="px-6 py-5">นักเรียน</th>
                            <th class="px-6 py-5">รหัสนักเรียน</th>
                            <th class="px-6 py-5">สถานะ</th>
                            <th class="px-6 py-5">วันที่สมัคร</th>
                            <th class="px-6 py-5 text-right">การจัดการ</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-white/[0.06]">
                        <% if (members && members.length > 0) { %>
                            <% members.forEach(member => { %>
                                <tr class="hover:bg-white/[0.03] transition-colors group">
                                    <td class="px-6 py-4">
                                        <div class="flex items-center gap-3">
                                            <div class="w-10 h-10 rounded-full bg-gradient-to-br from-white/10 to-white/5 flex items-center justify-center text-white font-bold border border-white/10 group-hover:shadow-neon-pink transition-all">
                                                <%= member.firstname.charAt(0) %>
                                            </div>
                                            <span class="text-white font-semibold"><%= member.firstname %> <%= member.lastname %></span>
                                        </div>
                                    </td>
                                    <td class="px-6 py-4 text-gray-400">
                                        <%= member.username %>
                                    </td>
                                    <td class="px-6 py-4">
                                        <span class="px-2.5 py-1 rounded-lg text-[10px] uppercase font-black tracking-widest border
                                            <%= member.status === 'approved' ? 'bg-emerald-500/10 text-emerald-400 border-emerald-500/30 shadow-[0_0_10px_rgba(16,185,129,0.2)]' : 
                                               (member.status === 'pending' ? 'bg-amber-500/10 text-amber-400 border-amber-500/30' : 
                                               'bg-red-500/10 text-red-400 border-red-500/30') %>">
                                            <%= member.status %>
                                        </span>
                                    </td>
                                    <td class="px-6 py-4 text-gray-500 text-sm">
                                        <%= new Date(member.registered_at).toLocaleDateString('th-TH') %>
                                    </td>
                                    <td class="px-6 py-4 text-right">
                                        <div class="flex justify-end gap-2">
                                            <% if (member.status === 'pending' || member.status === 'rejected') { %>
                                                <form action="/teacher/club/<%= club.id %>/member/<%= member.student_id %>/approve" method="POST">
                                                    <button type="submit" class="px-3 py-1.5 rounded-lg bg-emerald-500/20 text-emerald-400 hover:bg-emerald-500 hover:text-white transition-all text-xs font-bold border border-emerald-500/30">
                                                        อนุมัติ
                                                    </button>
                                                </form>
                                            <% } %>
                                            <% if (member.status === 'pending' || member.status === 'approved') { %>
                                                <form action="/teacher/club/<%= club.id %>/member/<%= member.student_id %>/reject" method="POST">
                                                    <button type="submit" class="px-3 py-1.5 rounded-lg bg-red-500/20 text-red-400 hover:bg-red-500 hover:text-white transition-all text-xs font-bold border border-red-500/30">
                                                        ปฏิเสธ
                                                    </button>
                                                </form>
                                            <% } %>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        <% } else { %>
                            <tr>
                                <td colspan="5" class="px-6 py-20 text-center text-gray-500 italic">
                                    ยังไม่มีนักเรียนสมัครเข้าร่วมชุมนุมนี้
                                </td>
                            </tr>
                        <% } %>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
