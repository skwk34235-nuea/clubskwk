<%- include('../partials/header') %>

<main class="flex-1 flex justify-center items-center p-4 relative overflow-hidden" style="min-height: calc(100vh - 130px);">
    <!-- Background Orbs -->
    <div class="absolute top-10 right-20 w-72 h-72 bg-neon-blue/15 rounded-full blur-[100px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute bottom-10 left-10 w-80 h-80 bg-skwkPink/15 rounded-full blur-[120px] animate-float pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-neon-purple/5 rounded-full blur-[150px] pointer-events-none"></div>

    <div class="w-full max-w-lg z-10 animate-slide-up">
        <div class="rounded-2xl bg-white/[0.03] backdrop-blur-2xl border border-white/[0.07] shadow-glass p-8 md:p-10 relative overflow-hidden">
            <!-- Top glow accent -->
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-neon-blue/60 to-transparent"></div>
            
            <!-- Header -->
            <div class="text-center mb-10">
                <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-neon-blue/20 to-skwkPink/20 border border-white/[0.08] flex items-center justify-center shadow-neon-blue">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-neon-blue" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z"/>
                    </svg>
                </div>
                <h2 class="text-3xl font-extrabold text-white tracking-wide">สมัครสมาชิก</h2>
                <p class="text-gray-500 mt-2 text-sm font-light">เข้าร่วมเป็นส่วนหนึ่งกับเรา</p>
            </div>

            <% if (locals.error) { %>
                <div class="bg-red-500/10 border border-red-500/30 text-red-300 p-4 mb-6 rounded-xl backdrop-blur-md flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <span class="font-medium text-sm"><%= error %></span>
                </div>
            <% } %>

            <form action="/auth/register" method="POST" class="space-y-5">
                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    <div class="space-y-2">
                        <label for="firstname" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">ชื่อ</label>
                        <input type="text" id="firstname" name="firstname" required 
                               class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300"
                               placeholder="First Name">
                    </div>
                    <div class="space-y-2">
                        <label for="lastname" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">นามสกุล</label>
                        <input type="text" id="lastname" name="lastname" required 
                               class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300"
                               placeholder="Last Name">
                    </div>
                </div>

                <div class="space-y-2">
                    <label for="username" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">รหัสนักเรียน / ชื่อผู้ใช้งาน</label>
                    <input type="text" id="username" name="username" required 
                           class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300"
                           placeholder="Student ID / Username">
                </div>
                
                <div class="space-y-2">
                    <label for="password" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">รหัสผ่าน</label>
                    <input type="password" id="password" name="password" required 
                           class="w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:bg-white/[0.06] focus:border-neon-blue/50 focus:shadow-neon-blue focus:outline-none transition-all duration-300"
                           placeholder="••••••••">
                </div>
                
                <button type="submit" class="group relative w-full py-4 rounded-xl text-white font-bold text-lg tracking-wide overflow-hidden transition-all duration-500 hover:scale-[1.02] hover:shadow-neon-blue mt-4">
                    <span class="absolute inset-0 bg-gradient-to-r from-neon-blue via-skwkPink to-neon-pink rounded-xl"></span>
                    <span class="absolute inset-0 bg-gradient-to-r from-neon-pink via-skwkPink to-neon-blue opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-xl"></span>
                    <span class="relative flex items-center justify-center gap-2">
                        สมัครสมาชิก
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6"/>
                        </svg>
                    </span>
                </button>
            </form>
            
            <!-- Divider -->
            <div class="mt-8 relative">
                <div class="absolute inset-0 flex items-center">
                    <div class="w-full border-t border-white/[0.06]"></div>
                </div>
                <div class="relative flex justify-center text-xs">
                    <span class="px-3 text-gray-600 bg-[#0a0a1a]">หรือ</span>
                </div>
            </div>

            <p class="mt-6 text-center text-gray-500 text-sm">
                มีบัญชีผู้ใช้แล้ว?
                <a href="/auth/login" class="text-white hover:text-neon-blue transition-all duration-300 font-semibold ml-1 inline-flex items-center gap-1">
                    เข้าสู่ระบบที่นี่
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                    </svg>
                </a>
            </p>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
