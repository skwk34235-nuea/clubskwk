<%- include('../partials/header') %>

<main class="flex-1 flex justify-center items-center p-4 relative overflow-hidden" style="min-height: calc(100vh - 130px);">
    <div class="absolute top-10 left-10 w-64 h-64 bg-skwkPink/20 rounded-full blur-[100px] animate-glow-pulse pointer-events-none"></div>
    <div class="absolute bottom-10 right-10 w-80 h-80 bg-neon-blue/15 rounded-full blur-[120px] animate-float pointer-events-none"></div>

    <div class="w-full max-w-md z-10 animate-slide-up">
        <div class="theme-panel rounded-2xl bg-white/[0.03] backdrop-blur-2xl border border-white/[0.07] shadow-glass p-8 md:p-10 relative overflow-hidden">
            <div class="absolute top-0 left-1/2 -translate-x-1/2 w-3/4 h-px bg-gradient-to-r from-transparent via-skwkPink/60 to-transparent"></div>

            <div class="text-center mb-10">
                <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-gradient-to-br from-skwkPink/20 to-neon-blue/20 border border-white/[0.08] flex items-center justify-center shadow-neon-pink">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7 text-skwkPink" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M11 16l-4-4m0 0l4-4m-4 4h14m-5 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h7a3 3 0 013 3v1"/>
                    </svg>
                </div>
                <h2 class="text-3xl font-extrabold text-white tracking-wide">เข้าสู่ระบบ</h2>
                <p class="text-gray-500 mt-2 text-sm font-light">เข้าใช้งานด้วยบัญชีที่ผู้ดูแลระบบสร้างให้</p>
            </div>

            <% if (locals.error) { %>
                <div class="bg-red-500/10 border border-red-500/30 text-red-300 p-4 mb-6 rounded-xl backdrop-blur-md flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-red-500/20 flex items-center justify-center flex-shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-red-400" viewBox="0 0 20 20" fill="currentColor">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7 4a1 1 0 11-2 0 1 1 0 012 0zm-1-9a1 1 0 00-1 1v4a1 1 0 102 0V6a1 1 0 00-1-1z" clip-rule="evenodd" />
                        </svg>
                    </div>
                    <span class="font-medium text-sm"><%= error %></span>
                </div>
            <% } %>

            <form action="/auth/login" method="POST" class="space-y-5">
                <div class="space-y-2">
                    <label for="username" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">ชื่อผู้ใช้งาน</label>
                    <input type="text" id="username" name="username" required class="theme-field w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:outline-none transition-all duration-300" placeholder="รหัสนักเรียน / Username">
                </div>

                <div class="space-y-2">
                    <label for="password" class="block text-xs font-semibold text-gray-400 uppercase tracking-[0.15em]">รหัสผ่าน</label>
                    <input type="password" id="password" name="password" required class="theme-field w-full px-4 py-3.5 rounded-xl bg-white/[0.03] border border-white/[0.08] text-white placeholder-gray-600 focus:outline-none transition-all duration-300" placeholder="••••••••">
                </div>

                <button type="submit" class="theme-primary-btn group relative w-full py-4 rounded-xl text-white font-bold text-lg tracking-wide overflow-hidden transition-all duration-500 hover:scale-[1.02] mt-4">
                    <span class="absolute inset-0 bg-gradient-to-r from-skwkBlue via-skwkPink to-neon-pink rounded-xl"></span>
                    <span class="absolute inset-0 bg-gradient-to-r from-neon-pink via-skwkPink to-skwkBlue opacity-0 group-hover:opacity-100 transition-opacity duration-700 rounded-xl"></span>
                    <span class="relative flex items-center justify-center gap-2">
                        เข้าสู่ระบบ
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M14 5l7 7m0 0l-7 7m7-7H3"/>
                        </svg>
                    </span>
                </button>
            </form>

            <p class="mt-6 text-center text-gray-500 text-sm">
                หากยังไม่มีบัญชีผู้ใช้ กรุณาติดต่อผู้ดูแลระบบเพื่อเพิ่มรายชื่อเข้าใช้งาน
            </p>
        </div>
    </div>
</main>

<%- include('../partials/footer') %>
